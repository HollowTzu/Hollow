name: Daily AI Market Analysis Update

on:
  schedule:
    # Runs automatically every day at 00:00 UTC (Adjust cron as needed)
    - cron: '0 0 * * *'
  # Allows you to trigger the run manually from GitHub Actions tab
  workflow_dispatch:

permissions:
  contents: write

jobs:
  run-ai-update:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Dependencies
        run: |
          python -m pip install --upgrade pip
          pip install google-genai pydantic beautifulsoup4

      - name: Run AI Dashboard Update
        env:
          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}
        run: |
          python update_dashboard.py

      - name: Commit and Push Updated index.html
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add index.html
          git diff --quiet && git diff --staged --quiet || (git commit -m "Auto-update market analysis via AI [skip ci]" && git push)
